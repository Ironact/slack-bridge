{
  "name": "slack-bridge",
  "version": "0.1.0",
  "description": "Use Slack as a real human, not a bot.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "slack-bridge": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "husky"
  },
  "keywords": [
    "slack",
    "bridge",
    "ai-agent",
    "openclaw",
    "automation"
  ],
  "author": "Ironact, Inc.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@slack/web-api": "^7.8.0",
    "commander": "^13.1.0",
    "fastify": "^5.2.1",
    "playwright": "^1.50.1",
    "zod": "^3.24.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "eslint": "^9.21.0",
    "husky": "^9.1.7",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7",
    "@vitest/coverage-v8": "^3.0.7"
  }
}
